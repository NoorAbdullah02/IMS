# Backend Environment Variables Example
# Copy this to .env and fill in your actual values

PORT=4000
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
JWT_SECRET=your_jwt_secret_key_change_me
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
BREVO_API_KEY=your_brevo_api_key
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# ============= VAPI AI Configuration =============
# Get these from https://dashboard.vapi.ai

# Private key (keep this secret - never expose to frontend!)
VAPI_PRIVATE_KEY=your_vapi_private_key_here

# Public key (safe to expose to frontend)
VAPI_PUBLIC_KEY=your_vapi_public_key_here

# Your Vapi Assistant ID (created in Vapi Dashboard)
# Format: UUID or custom ID from Vapi Dashboard
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# ============= NVIDIA AI Configuration =============
# Get these from https://build.nvidia.com (NVIDIA NIM)
# Used for AI-powered chat responses

# NVIDIA Client ID (OAuth2)
NVIDIA_CLIENT_ID=your_nvidia_client_id_here

# NVIDIA Client Secret (OAuth2)
NVIDIA_CLIENT_SECRET=your_nvidia_client_secret_here
